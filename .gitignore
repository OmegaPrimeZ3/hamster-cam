# Node / build output
node_modules/
dist/
build/
*.tsbuildinfo
.vite/
coverage/
.turbo/

# Playwright e2e output
/e2e/test-results/
/e2e/playwright-report/
/e2e/.tsbuild/
/e2e/artifacts/

/.claude/

# Docs to not share
/docs/PLAN.md
/docs/EXECUTION.md

# Environment files — keep .env.example tracked, ignore real values
.env
.env.local
.env.*.local
!.env.example

# Frigate config — host-authoritative (Frigate's zone editor writes back
# into it, it holds the host's WebRTC LAN IP, and it accumulates
# operator-tuned masks). Keep the .example template tracked, ignore the
# real file. Seed it once with:
#   cp mac-mini/frigate-config.example.yml mac-mini/frigate-config.yml
/mac-mini/frigate-config.yml
!/mac-mini/frigate-config.example.yml

# SQLite database files and on-host storage
/db/*.db
/db/*.db-*
*.sqlite
/storage/

# Local dev sandbox produced by `pnpm -F server dev`
/.dev/

# OS noise
.DS_Store
Thumbs.db
*.log
.vscode/*.log

# Editor backups
*~
*.swp
*.swo

# Python (Frigate runs in Docker but local trainer/tooling scripts may land in-tree)
__pycache__/
*.pyc
.venv/

# pet-model pipeline: never commit model weights/datasets/exports if a misconfigured
# work_dir lands them in-tree (the pipeline writes these OUTSIDE the repo by default).
*.onnx
*.pt
/scripts/pet-model/pets/*.local.yaml

# EXCEPTION: curated, versioned detector releases under models/ ARE tracked on
# purpose (the deployable ONNX + labelmap + training weights for each version).
# This overrides the *.onnx / *.pt ignore above for this directory only.
!/models/
!/models/**

# Mask audit run artifacts — regenerated on demand, not source of truth
scripts/mask-audit/out/
