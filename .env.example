# =============================================================
# hamster-cam — environment file (example)
# Copy to .env and fill in real values. NEVER commit .env.
# Lives at /opt/hamster-cam/.env on the Mac Mini.
# =============================================================


# -------------------------------------------------------------
# Zyphr.dev — authentication
# -------------------------------------------------------------

# Zyphr application credentials — both are REQUIRED.
# Obtain from: Zyphr dashboard → Applications → your app → Keys & Secrets.
# The Application Key and Application Secret are sent as two distinct HTTP
# headers (X-Application-Key and X-Application-Secret). Passing only one value
# causes Zyphr to reject ALL auth calls with "invalid application credentials".
# IMPORTANT: the Key and Secret must be from the SAME Zyphr environment.
# Test-environment keys (zy_test_…) will NOT work with a live-environment
# Secret, and vice versa.
ZYPHR_API_KEY=zy_live_REPLACE_ME_KEY
ZYPHR_APP_SECRET=zy_live_REPLACE_ME_SECRET

# Optional. Override only when testing against a staging tenant.
# The key/secret pair above must be from this same environment.
# ZYPHR_BASE_URL=https://api.zyphr.dev/v1

# Sender address for Zyphr-delivered emails (Send-a-Clip flow, disk-critical alerts).
# Must be a domain verified in your Zyphr dashboard. Without this, share.send fails
# and disk-watch will skip critical alerts (still writes diary entries).
ZYPHR_FROM_EMAIL=cam@remy-hamster.com


# -------------------------------------------------------------
# Cloudflare — dynamic DNS + Let's Encrypt DNS-01
# -------------------------------------------------------------

# Scoped API token from Cloudflare dashboard:
#   My Profile → API Tokens → Create Token
#   Permissions: Zone : DNS : Edit
#   Zone Resources: include ONLY your specific zone
# Used by both the cloudflare-ddns container AND by Caddy's
# DNS-01 challenge for issuing certificates.
CLOUDFLARE_API_TOKEN=REPLACE_ME

# Your apex domain at Cloudflare and the subdomain the cam runs on.
CLOUDFLARE_ZONE=remy-hamster.com
CLOUDFLARE_SUBDOMAIN=cam


# -------------------------------------------------------------
# Camera RTSP credentials
# -------------------------------------------------------------

# Locks the go2rtc RTSP listener on each Pi Zero so a compromised
# LAN device can't pull live video. The same password is used by
# Frigate on the Mac Mini to pull the streams — keep them in sync.
# Generate with: openssl rand -base64 24
RTSP_USERNAME=hamster
RTSP_PASSWORD=REPLACE_with_long_random_string
FRIGATE_RTSP_PASSWORD=${RTSP_PASSWORD}


# -------------------------------------------------------------
# MQTT broker — Mosquitto
# -------------------------------------------------------------

# Frigate publishes events here; the backend subscribes. Enable
# username/password auth on Mosquitto via its passwd file rather
# than running it open even on the Docker network.
#
# DOCKER (current): the backend runs as `hamster-app` on the compose network,
# so the Docker service name `mosquitto` resolves correctly via Docker DNS.
# HOST (rollback/systemd path): if you run the backend as a host systemd
# service instead, Docker DNS does not reach the host process — use
# `mqtt://127.0.0.1:1883` (Mosquitto publishes port 1883 to localhost).
MQTT_URL=mqtt://mosquitto:1883
MQTT_USERNAME=hamster
MQTT_PASSWORD=REPLACE_with_long_random_string


# -------------------------------------------------------------
# Frigate
# -------------------------------------------------------------

# Reached by the backend for snapshots, camera discovery (go2rtc stream names),
# per-camera last-frame stats, AND the live-view WS proxy (/api/go2rtc/api/ws).
#
# DOCKER (current): the backend runs on the compose network alongside Frigate,
# so the Docker service name `frigate` resolves correctly via Docker DNS.
# HOST (rollback/systemd path): if you run the backend as a host systemd
# service, use `http://127.0.0.1:5000` — Frigate publishes port 5000 to
# localhost. Using the Docker name from a host process causes
# "Stream name not found in go2rtc" and camera tiles stuck on "loading".
FRIGATE_URL=http://frigate:5000

# Frigate's own MQTT credentials (it uses the same broker).
# Frigate reads these from its config; they reference these vars.
# (No separate value needed — Frigate uses MQTT_USERNAME / MQTT_PASSWORD above.)


# -------------------------------------------------------------
# App backend — Fastify + tRPC
# -------------------------------------------------------------

# Local port the Fastify app listens on. Caddy reverse-proxies to it.
PORT=3000

# SQLite database file. Must be on a path the app user owns.
DATABASE_PATH=/opt/hamster-cam/db/hamster.db

# Where snapshots and nightly time-lapse MP4s are written.
STORAGE_PATH=/opt/hamster-cam/storage

# How long a session cookie lasts before re-login is required.
SESSION_TTL_DAYS=30

# Absolute path to the built React SPA. REQUIRED in the Docker container
# because the relative-path fallback (../../web/dist from dist/index.js)
# does not resolve in the container's flat layout (/app/dist/ vs /app/web/dist/).
# This is set explicitly in docker-compose.yml's hamster-app environment block.
# When running the backend as a host systemd service (rollback path), you can
# unset this and rely on the relative-path default if your layout matches the
# monorepo tree, or set it explicitly to /opt/hamster-cam/app/web/dist.
WEB_DIST_PATH=/app/web/dist

# The public-facing HTTPS origin for the deployed site (e.g. from CADDY_HOSTNAME).
# Used by the live-view WS proxy's Origin allowlist to block cross-site WS
# hijacking. When set, the allowlist contains exactly this origin. When unset
# in development, the VITE_DEV_ORIGINS list covers localhost.
#
# In production: set to  https://<CADDY_HOSTNAME>
# In docker-compose this can be  PUBLIC_URL=https://${CADDY_HOSTNAME}
PUBLIC_URL=example.com

# -------------------------------------------------------------
# Google Gemini — optional AI daily storybook recap
# -------------------------------------------------------------
#
# Each morning at 06:10 local the backend can call Google Gemini to
# write a warm 2–4 sentence storybook paragraph summarizing the
# overnight window (21:00 the previous evening → 06:00 this morning).
# Pinned to the top of that morning's diary alongside the time-lapse.
#
# OPTIONAL. If GEMINI_API_KEY is unset the recap job logs and
# skips cleanly — every other feature keeps working.
#
# Get a free key:  https://aistudio.google.com/app/apikey
#   Google account → "Get API key" → "Create API key" → copy.
#   Free tier (Gemini 2.5 Flash) gives generous daily limits, way
#   more than the 1/night this app uses.
#
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.5-flash


# -------------------------------------------------------------
# Caddy — TLS + non-standard port
# -------------------------------------------------------------

# The non-standard HTTPS port Caddy listens on. The router forwards
# TCP+UDP 2053 → Mac Mini:2053. Cloudflare's Origin Rule maps the
# edge's public :443 → your origin's :2053 so visitors use the
# clean URL with no port suffix. Stay on Cloudflare's list of
# proxied-HTTPS-supported ports (443, 2053, 2083, 2087, 2096, 8443).
CADDY_HTTPS_PORT=2053

# Email used as the Let's Encrypt account contact (expiry notifications).
CADDY_EMAIL=you@remy-hamster.com

# The fully-qualified hostname your site serves at.
CADDY_HOSTNAME=cam.remy-hamster.com

# Public origin of the deployed site. REQUIRED in production for the live-view
# WebSocket proxy: the /live/ws endpoint validates the browser's Origin header
# against this to prevent cross-site WebSocket hijacking (a malicious page
# slurping your camera feed via a logged-in session). Set it to https:// +
# CADDY_HOSTNAME. If unset in production, ALL live-view WebSockets are rejected
# (fail-secure) and feeds stay dark.
PUBLIC_URL=https://cam.remy-hamster.com

# Optional: comma-separated extra browser origins allowed to open the live-view
# WebSocket, for local development only (e.g. the Vite dev server). The Vite
# default http://localhost:5173 is already allowed in dev; leave blank otherwise.
# DEV_ORIGINS=


# -------------------------------------------------------------
# Container UID alignment
# -------------------------------------------------------------

# The hamster-app container runs as the `node` user (uid 1000, gid 1000).
# The bind-mounted host dirs (./db and ./storage under MAC_MINI_PATH) must
# be owned and writable by the same uid/gid. If your Mac Mini deploy user
# also has uid 1000 (check with `id -u` on the Mini) you need no chown —
# set these to 1000. If your uid differs, set the correct values and run:
#   sudo chown -R ${HOST_UID}:${HOST_GID} /opt/hamster-cam/db
#   sudo chown -R ${HOST_UID}:${HOST_GID} /opt/hamster-cam/storage
# Defaults to 1000:1000 (the node image's built-in node user).
HOST_UID=1000
HOST_GID=1000


# -------------------------------------------------------------
# Deploy
# -------------------------------------------------------------

# Consumed by deploy.sh when pushing builds from the dev machine
# to the Mac Mini over SSH.
MAC_MINI_HOST=hamster-mac.local
MAC_MINI_USER=hamster
MAC_MINI_PATH=/opt/hamster-cam


# -------------------------------------------------------------
# Host timezone
# -------------------------------------------------------------

# Used by Frigate (clip filenames, event timestamps in the UI) and
# the cloudflare-ddns container's log timestamps. Any IANA tz name
# works — America/Los_Angeles, Europe/London, Asia/Tokyo, etc.
# Defaults to UTC if unset.
TZ=Etc/UTC


# -------------------------------------------------------------
# Pi Zero RTSP env file (separate file, NOT this one)
# -------------------------------------------------------------
#
# On each Pi Zero, /etc/go2rtc/go2rtc.env (chmod 600, root-owned)
# contains only:
#
#     RTSP_PASSWORD=<same value as above>
#
# The go2rtc systemd unit references it via EnvironmentFile=.
# Do not put Pi Zero secrets in this Mac-Mini-side .env.
